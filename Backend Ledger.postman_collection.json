    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccount\": \"{{accountId}}\",\n  \"toAccount\": \"{{receiverAccountId}}\",\n  \"amount\": 100,\n  \"idempotencyKey\": \"{{idempotencyKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions"
              ]
            },
            "description": "This endpoint has an intentional 15-second delay in the controller. Sender account must already have enough balance."
          }
        },
        {
          "name": "Create Initial Funds Transaction",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{systemToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"toAccount\": \"{{accountId}}\",\n  \"amount\": 1000,\n  \"idempotencyKey\": \"initial-funds-{{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/system/initial-funds",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions",
                "system",
                "initial-funds"
              ]
            },
            "description": "Requires a JWT for a user whose systemUser field is true. Paste that JWT into the systemToken collection variable before sending."
          }
        }
