            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sourabh User\",\n  \"email\": \"sourabh{{$timestamp}}@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
